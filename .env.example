# Server
PORT=3001
NODE_ENV=development

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=driveledger
DB_PASSWORD=driveledger
DB_NAME=driveledger
DB_ROOT_PASSWORD=rootpassword

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# SMTP Configuration (optional - emails will be logged to console if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=DriveLedger <noreply@driveledger.app>

# Email Toggle (true/false) - when false, email features are disabled
# Forgot password works via admin-generated tokens, registration skips email verification
EMAIL_ENABLED=false

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Initial Admin User (created on first startup if no users exist)
ADMIN_EMAIL=admin@driveledger.app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# OIDC/SSO Configuration (optional)
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_REDIRECT_URL=http://localhost:3001/api/oidc/callback
OIDC_SCOPE=openid email profile
OIDC_PROVIDER_NAME=SSO

# Allowed File Extensions for uploads (comma-separated)
ALLOWED_FILE_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.gif,.doc,.docx,.xls,.xlsx,.csv,.txt,.zip

# Cookie Lifespan (days)
COOKIE_LIFESPAN_DAYS=7

# Default Reminder Email (used when a reminder has no explicit email)
DEFAULT_REMINDER_EMAIL=

# Copy supply attachments to records when requisitioning (true/false)
COPY_SUPPLIES_ATTACHMENT=false

# Open Registration (if true, no registration token is needed)
OPEN_REGISTRATION=false

# Custom Branding (optional)
CUSTOM_LOGO_URL=
CUSTOM_MOTD=
